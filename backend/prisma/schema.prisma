generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum Role {
  STUDENT
  ADMIN
  VERIFIER
  ACCOUNTS
}

enum CasteCategory {
  GENERAL
  GENERAL_EWS
  OBC_NCL
  SC
  ST
}

enum SeatAllotmentSource {
  JOSSA
  CSAB
}

enum ApplicationStatus {
  PENDING
  IN_REVIEW
  DOCUMENTS_REJECTED
  VERIFIED
  FEE_PENDING
  CONFIRMED
  REJECTED
}

enum DocumentType {
  PASSPORT_PHOTO
  PROVISIONAL_LETTER
  CLASS_10_MARKSHEET
  CLASS_12_MARKSHEET
  JEE_RANK_CARD
  CASTE_CERTIFICATE
  PWD_CERTIFICATE
  MEDICAL_CERTIFICATE
  INSTITUTE_FEE_RECEIPT
  HOSTEL_FEE_RECEIPT
  UNDERTAKING
  CLASS_12_PERFORMANCE
  AADHAR_CARD
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
  SUPERSEDED
}

// ============================================
// MODELS
// ============================================

model Batch {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  startYear Int?
  endYear   Int?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studentProfiles StudentProfile[]
  branchIntakes   BranchIntake[]

  @@index([isActive])
  @@index([startYear, endYear])
}

model Branch {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studentProfiles StudentProfile[]
  branchIntakes   BranchIntake[]

  @@index([isActive])
  @@index([name])
}

model BranchIntake {
  id        String   @id @default(cuid())
  branchId  String
  batchId   String
  intake    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  batch  Batch  @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([branchId, batchId])
  @@index([branchId])
  @@index([batchId])
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(STUDENT)
  createdAt DateTime @default(now())

  // Nextauth fields for session management
  emailVerified  DateTime?
  image          String?
  accounts       Account[]
  sessions       Session[]
  studentProfile StudentProfile?

  remarks Remark[]

  verifierAssignments Assignment[] @relation("VerifierAssignments")
  assignerAssignments Assignment[] @relation("AssignerAssignments")
}

model StudentProfile {
  id String @id @default(cuid())

  // Personal Information
  name          String
  dateOfBirth   DateTime
  contactNumber String
  aadharNumber  String
  bloodGroup    String?

  // Guardian Information
  guardianName   String
  guardianNumber String
  guardianEmail  String

  // Social Category
  religion      String
  casteCategory CasteCategory

  // Academic Information
  branchAllotted          String
  branchId                String?
  batchId                 String?
  gender                  String?
  isPwd                   Boolean?
  pwdDisabilityType       String?
  jeeMainRank             Int?
  jeeMainCategoryRank     Int?
  jeeAdvancedRank         Int?
  jeeAdvancedCategoryRank Int?
  seatAllotmentSource     SeatAllotmentSource

  // Address
  permanentAddress String
  state            String

  // Application Metadata
  remarksFromStudent String?
  applicationStatus  ApplicationStatus @default(PENDING)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  userId      String       @unique
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch      Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  batch       Batch?       @relation(fields: [batchId], references: [id], onDelete: SetNull)
  documents   Document[]
  assignments Assignment[]
  Remark      Remark[]

  @@index([applicationStatus])
  @@index([branchAllotted])
  @@index([branchId])
  @@index([batchId])
  @@index([state])
}

model Document {
  id String @id @default(cuid())

  // Document Information
  documentType DocumentType
  fileUrl      String
  fileName     String
  fileSize     Int?

  // Status Tracking
  status          DocumentStatus @default(PENDING)
  rejectionReason String?

  // Version Tracking
  version           Int     @default(1)
  previousVersionId String?

  // Timestamps
  uploadedAt DateTime  @default(now())
  verifiedAt DateTime?
  verifiedBy String?

  // Relations
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@unique([studentProfileId, documentType, version])
  @@index([studentProfileId, documentType])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Assignment {
  id            String   @id @default(cuid())
  applicationId String   @unique
  verifierId    String
  assignedBy    String
  assignedAt    DateTime @default(now())

  application StudentProfile @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  verifier    User           @relation("VerifierAssignments", fields: [verifierId], references: [id])
  assigner    User           @relation("AssignerAssignments", fields: [assignedBy], references: [id])

  @@index([verifierId])
  @@index([applicationId])
}

model Remark {
  id            String   @id @default(cuid())
  applicationId String
  authorId      String
  text          String   @db.Text
  createdAt     DateTime @default(now())

  application StudentProfile @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  author      User           @relation(fields: [authorId], references: [id])

  @@index([applicationId])
  @@index([authorId])
}
